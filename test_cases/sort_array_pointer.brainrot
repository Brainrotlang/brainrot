skibidi swap(rizz *a, rizz *b) {
    rizz tmp = *a;
    *a = *b;
    *b = tmp;
}

skibidi sort_array(rizz *arr, rizz n) {
    rizz i;
    rizz j;

    flex (i = 0; i < n - 1; i = i + 1) {
        flex (j = 0; j < n - i - 1; j = j + 1) {
            rizz left = *(arr + j);
            rizz right = *(arr + (j + 1));

            edgy (left > right) {
                swap(arr + j, arr + (j + 1));
            }
        }
    }

}

skibidi main {
    rizz values[5] = {5, 1, 4, 2, 3};
    sort_array(&values[0], 5);

    rizz k;
    flex (k = 0; k < 5; k = k + 1) {
        yapping("%d", values[k]);
    }

    bussin 0;
}
